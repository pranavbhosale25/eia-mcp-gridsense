{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.pranavbhosale25/eia-mcp-gridsense",
  "description": "MCP server for US electricity grid data: fuel mix, demand, retail prices, CO2 emissions",
  "repository": {
    "url": "https://github.com/pranavbhosale25/eia-mcp-gridsense",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "eia-mcp-gridsense",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your EIA API key (register at https://www.eia.gov/opendata/register.php)",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "EIA_API_KEY"
        }
      ]
    }
  ]
}